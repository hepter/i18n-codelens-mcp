{
  "name": "i18n-codelens-mcp",
  "version": "1.0.0",
  "description": "MCP server for i18n translation management — scan, diff, upsert, rename, and validate locale resources from AI agents.",
  "private": false,
  "main": "./out/index.js",
  "types": "./out/index.d.ts",
  "bin": {
    "i18n-codelens-mcp": "out/server.js"
  },
  "exports": {
    ".": {
      "require": "./out/index.js",
      "types": "./out/index.d.ts"
    },
    "./server": {
      "require": "./out/server.js",
      "types": "./out/server.d.ts"
    },
    "./config": {
      "require": "./out/config.js",
      "types": "./out/config.d.ts"
    },
    "./i18nFs": {
      "require": "./out/i18nFs.js",
      "types": "./out/i18nFs.d.ts"
    },
    "./resourceUtils": {
      "require": "./out/resourceUtils.js",
      "types": "./out/resourceUtils.d.ts"
    },
    "./toolUtils": {
      "require": "./out/toolUtils.js",
      "types": "./out/toolUtils.d.ts"
    }
  },
  "files": [
    "out/**",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p ./ && node ./scripts/ensure-bin-mode.cjs",
    "watch": "tsc -watch -p ./",
    "check": "npm run build && npm test",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "i18n",
    "localization",
    "translation",
    "mcp",
    "model-context-protocol",
    "ai"
  ],
  "author": {
    "email": "mustafakuru042@gmail.com",
    "name": "Mustafa Kuru"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/hepter/i18n-codelens-mcp.git"
  },
  "bugs": {
    "url": "https://github.com/hepter/i18n-codelens-mcp/issues"
  },
  "homepage": "https://github.com/hepter/i18n-codelens-mcp#readme",
  "publishConfig": {
    "access": "public"
  },
  "sideEffects": false,
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "fast-glob": "^3.3.2",
    "fastest-levenshtein": "^1.0.16",
    "ignore": "^7.0.5",
    "zod": "^3.25.76"
  },
  "overrides": {
    "@hono/node-server": "^1.19.14",
    "express-rate-limit": "^8.5.1",
    "fast-uri": "^3.1.2",
    "hono": "^4.12.18",
    "ip-address": "^10.2.0",
    "path-to-regexp": "^8.4.2",
    "picomatch": "^2.3.2",
    "brace-expansion": "^5.0.6",
    "postcss": "^8.5.14"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@vitest/coverage-v8": "^3.2.4",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  }
}
